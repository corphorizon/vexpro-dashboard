# ─── Public app URL ─────────────────────────────────────────────
# Used as fallback in password-reset emails when the request has no
# Origin/Host header. In production this is the canonical URL.
NEXT_PUBLIC_APP_URL=https://dashboard.horizonconsulting.ai

# Supabase Configuration
# Get these from: https://supabase.com → Your Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Cron job auth (REQUIRED for daily-balance-snapshot) ────────
# Random secret. Any /api/cron/* route validates Bearer <CRON_SECRET>.
# Must match the header Vercel sends in its cron config.
# Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
CRON_SECRET=your_random_cron_secret_here

# ─── Direct Postgres (ONLY for scripts/db-admin/*) ───────────────
# Not needed by the Next.js runtime. Used by db-admin scripts that
# run DDL and bypass PostgREST. Never commit real values.
SUPABASE_DB_HOST=aws-0-us-east-2.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=your_db_password_here

# SendGrid Email Configuration
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@horizonconsulting.com
SENDGRID_FROM_NAME=Horizon Consulting

# API Credentials Master Key (Settings module — encryption AES-256-GCM)
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# DO NOT rotate without re-encrypting all stored credentials!
API_CREDENTIALS_MASTER_KEY=your_32_byte_base64_key_here

# Coinsbuy v3 API (OAuth 2.0)
# Get credentials from your Coinsbuy merchant dashboard
# Leave empty or set CLIENT_ID=mock to use mock data
COINSBUY_CLIENT_ID=your_client_id_here
COINSBUY_CLIENT_SECRET=your_client_secret_here
COINSBUY_BASE_URL=https://v3.api.coinsbuy.com

# UniPayment API (OAuth 2.0)
# Get credentials from UniPayment dashboard → API Management → Add Open Client
# Leave empty or set CLIENT_ID=mock to use mock data
UNIPAYMENT_CLIENT_ID=your_client_id_here
UNIPAYMENT_CLIENT_SECRET=your_client_secret_here
UNIPAYMENT_BASE_URL=https://api.unipayment.io

# FairPay API (Bearer JWT — two-step token flow)
# Get the api_key from your FairPay merchant panel.
# Leave empty or set FAIRPAY_API_KEY=mock to use mock data.
# Production: https://portal.fairpay.online
# Sandbox:    https://sandbox-portal.fairpay.online
FAIRPAY_API_KEY=your_merchant_api_key_here
FAIRPAY_BASE_URL=https://portal.fairpay.online

# Fixie SOCKS5 Proxy — provides static outbound IPs for Coinsbuy whitelist.
# Leave empty to call APIs directly (local dev / unrestricted networks).
# Format: socks5://user:pass@host:port
# Dashboard: https://usefixie.com/dashboard
FIXIE_URL=

# ─── Sentry (opcional — monitoring de errores) ──────────────────────────
# Si están vacíos, Sentry es no-op (no se envían eventos). Para activar:
#   1. Crear proyecto en https://sentry.io → copiar DSN
#   2. Pegar mismo valor en NEXT_PUBLIC_SENTRY_DSN (cliente) y SENTRY_DSN (servidor)
#   3. En Vercel, agregar las 4 vars en Settings → Environment Variables
# SENTRY_ORG / SENTRY_PROJECT solo son necesarios para source-map upload.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Orion CRM (opcional — fallback global si el tenant no tiene creds) ─
# Las credenciales reales van por-tenant en la tabla api_credentials
# (provider='orion_crm') desde el panel de superadmin.
# Estas vars son el FALLBACK — si un tenant no tiene creds propias cae aquí.
# Si ambas están vacías Y ORION_CRM_ENABLE_MOCK_FALLBACK=true, las
# llamadas devuelven datos mock realistas (útil durante desarrollo).
ORION_CRM_API_KEY=
ORION_CRM_BASE_URL=https://api.orion-crm.example

# Cuando no hay credenciales, servir mocks en lugar de empty/error.
# Deja 'true' en dev/preview. En prod ponelo en 'false' si preferís que
# la ausencia de creds sea un error visible.
ORION_CRM_ENABLE_MOCK_FALLBACK=true

# ─── 2FA bypass en local (SOLO LOCAL, NUNCA PROD) ────────────────────────
# Saltea el prompt de 2FA durante desarrollo local.
# Doble gate: NODE_ENV!='production' Y hostname=localhost. Aunque pongas
# estos 'true' en Vercel, el hostname gate del cliente + el NODE_ENV
# del servidor los ignoran. Dejá ambos vacíos en Vercel.
DEV_SKIP_2FA=false
NEXT_PUBLIC_DEV_SKIP_2FA=false
